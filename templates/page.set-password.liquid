{% comment %}
  Set Password Page Template — set-password.liquid
  ══════════════════════════════════════════════════
  HOW TO INSTALL:
  1. Shopify Admin → Online Store → Themes → Edit Code
  2. Templates → Add template → page → liquid → name it "set-password" → Save
  3. Online Store → Pages → Add page
       Title: "Set Password"
       Template: page.set-password
       Visibility: Hidden (customers only land here via email link)
       → Save
  4. Only change needed: set CONNECTOR_URL to your Render app URL.
  ══════════════════════════════════════════════════
  How it works:
  - Email link: https://yourstore.com/pages/set-password?token=xxxxx
  - This page reads ?token= from the URL
  - Customer enters + confirms new password
  - Page POSTs to connector /multipass/set-password (JSON)
  - On success, shows confirmation + link to login page
  ══════════════════════════════════════════════════
{% endcomment %}

{% assign CONNECTOR_URL = "https://odoo-connector-oivx.onrender.com" %}

<style>
  .sp-wrap {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 16px;
  }
  .sp-card {
    background: #fff;
    border: 1px solid #e1e3e5;
    border-radius: 8px;
    box-shadow: 0 1px 3px rgba(63,63,68,.15);
    padding: 36px 40px;
    width: 100%;
    max-width: 420px;
  }
  .sp-card h2 {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 4px;
    color: #202223;
  }
  .sp-card .subtitle {
    font-size: 14px;
    color: #6d7175;
    margin-bottom: 28px;
  }
  .sp-label {
    font-size: 13px;
    font-weight: 600;
    color: #202223;
    margin-bottom: 6px;
    display: block;
  }
  .sp-input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #d2d5d8;
    border-radius: 6px;
    font-size: 14px;
    color: #202223;
    outline: none;
    transition: border-color .15s;
    margin-bottom: 16px;
    box-sizing: border-box;
  }
  .sp-input:focus {
    border-color: #005bd3;
    box-shadow: 0 0 0 2px rgba(0,91,211,.15);
  }
  .sp-btn {
    width: 100%;
    padding: 11px;
    background: #202223;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background .15s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .sp-btn:hover:not(:disabled) { background: #444; }
  .sp-btn:disabled { opacity: .65; cursor: not-allowed; }
  .sp-alert {
    padding: 10px 14px;
    border-radius: 6px;
    font-size: 13px;
    margin-bottom: 16px;
    display: none;
  }
  .sp-alert.error   { background: #fff4f4; border: 1px solid #fca5a5; color: #d82c0d; }
  .sp-alert.success { background: #e3f1df; border: 1px solid #cce5cc; color: #008060; }
  .sp-spinner {
    width: 16px; height: 16px;
    border: 2px solid rgba(255,255,255,.4);
    border-top-color: #fff;
    border-radius: 50%;
    animation: sp-spin .6s linear infinite;
    display: none;
  }
  @keyframes sp-spin { to { transform: rotate(360deg); } }
  .sp-footer {
    text-align: center;
    font-size: 13px;
    color: #6d7175;
    margin-top: 20px;
    border-top: 1px solid #e1e3e5;
    padding-top: 18px;
  }
  .sp-footer a { color: #005bd3; text-decoration: none; }
  .sp-footer a:hover { text-decoration: underline; }
</style>

<div class="sp-wrap">
  <div class="sp-card" id="mainCard">

    <!-- Loading state while we validate the token -->
    <div id="loadingState">
      <h2>Verifying link…</h2>
      <p class="subtitle">Please wait a moment.</p>
    </div>

    <!-- Invalid / expired token -->
    <div id="invalidState" style="display:none;">
      <h2>Link Invalid</h2>
      <p class="subtitle">This link is invalid or has already been used.</p>
      <p style="font-size:13px; color:#6d7175;">
        Return to the login page and click "Set up or reset password" to request a new link.
      </p>
      <div class="sp-footer">
        <a href="/pages/b2b-login">← Back to login</a>
      </div>
    </div>

    <!-- Expired token -->
    <div id="expiredState" style="display:none;">
      <h2>Link Expired</h2>
      <p class="subtitle">This link has expired (valid for 7 days).</p>
      <p style="font-size:13px; color:#6d7175;">
        Return to the login page and click "Set up or reset password" to request a new link.
      </p>
      <div class="sp-footer">
        <a href="/pages/b2b-login">← Back to login</a>
      </div>
    </div>

    <!-- Set password form -->
    <div id="formState" style="display:none;">
      <h2>Set Your Password</h2>
      <p class="subtitle">Enter a new password for your B2B ordering account.</p>

      <div id="spAlert" class="sp-alert" role="alert"></div>

      <label class="sp-label" for="spPassword">New Password</label>
      <input type="password" id="spPassword" class="sp-input"
             placeholder="Minimum 8 characters" minlength="8"
             autocomplete="new-password" />

      <label class="sp-label" for="spConfirm">Confirm Password</label>
      <input type="password" id="spConfirm" class="sp-input"
             placeholder="Repeat your password" minlength="8"
             autocomplete="new-password" />

      <button class="sp-btn" id="spBtn" onclick="submitPassword()">
        <span class="sp-spinner" id="spSpinner"></span>
        <span id="spBtnText">Set Password</span>
      </button>

      <div class="sp-footer">
        <a href="/pages/b2b-login">← Back to login</a>
      </div>
    </div>

    <!-- Success state -->
    <div id="successState" style="display:none;">
      <h2>Password Set! ✓</h2>
      <p class="subtitle">Your password has been set successfully.</p>
      <p style="font-size:13px; color:#6d7175; margin-bottom:20px;">
        You can now log in using your Store ID and the password you just created.
      </p>
      <a href="/pages/b2b-login" class="sp-btn" style="text-decoration:none; justify-content:center;">
        Go to Login
      </a>
    </div>

  </div>
</div>

<script>
  const CONNECTOR = "{{ CONNECTOR_URL }}";

  // Read token from URL query param
  const urlParams = new URLSearchParams(window.location.search);
  const token = urlParams.get('token') || '';

  function showState(id) {
    ['loadingState', 'invalidState', 'expiredState', 'formState', 'successState']
      .forEach(s => document.getElementById(s).style.display = s === id ? 'block' : 'none');
  }

  function showAlert(message, type) {
    const el = document.getElementById('spAlert');
    el.className = `sp-alert ${type}`;
    el.textContent = message;
    el.style.display = 'block';
  }

  // On load: validate the token exists (quick check via length)
  window.addEventListener('DOMContentLoaded', () => {
    if (!token || token.length < 10) {
      showState('invalidState');
    } else {
      // Token looks valid — show the form
      // Server will validate it properly on submit
      showState('formState');
      document.getElementById('spPassword').focus();
    }
  });

  async function submitPassword() {
    const password = document.getElementById('spPassword').value.trim();
    const confirm  = document.getElementById('spConfirm').value.trim();

    if (!password || password.length < 8) {
      showAlert('Password must be at least 8 characters.', 'error');
      return;
    }
    if (password !== confirm) {
      showAlert('Passwords do not match.', 'error');
      return;
    }

    // Loading state
    document.getElementById('spSpinner').style.display = 'inline-block';
    document.getElementById('spBtnText').textContent = 'Setting password…';
    document.getElementById('spBtn').disabled = true;
    document.getElementById('spAlert').style.display = 'none';

    try {
      const resp = await fetch(`${CONNECTOR}/multipass/set-password`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, password, confirm_password: confirm })
      });
      const data = await resp.json();

      if (data.success) {
        showState('successState');
      } else {
        const msg = data.error || 'Something went wrong. Please try again.';
        // Check if token expired/invalid
        if (msg.toLowerCase().includes('expired')) {
          showState('expiredState');
        } else if (msg.toLowerCase().includes('invalid') || msg.toLowerCase().includes('already been used')) {
          showState('invalidState');
        } else {
          showAlert(msg, 'error');
          document.getElementById('spSpinner').style.display = 'none';
          document.getElementById('spBtnText').textContent = 'Set Password';
          document.getElementById('spBtn').disabled = false;
        }
      }
    } catch (err) {
      showAlert('Connection error. Please try again.', 'error');
      document.getElementById('spSpinner').style.display = 'none';
      document.getElementById('spBtnText').textContent = 'Set Password';
      document.getElementById('spBtn').disabled = false;
    }
  }

  // Enter key support
  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('spPassword').addEventListener('keydown', e => {
      if (e.key === 'Enter') document.getElementById('spConfirm').focus();
    });
    document.getElementById('spConfirm').addEventListener('keydown', e => {
      if (e.key === 'Enter') submitPassword();
    });
  });
</script>
