<style type="text/css">
  .template-404 .title + * {
    margin-top: 1rem;
  }

  @media screen and (min-width: 750px) {
    .template-404 .title + * {
      margin-top: 2rem;
    }
  }
</style>

<div class="template-404 page-width page-margin center">
  <p class="caption-with-letter-spacing light t2">
    {{ 'templates.404.subtext' | t }}
  </p>
  <h1 class="b-main-title">
    {{ 'templates.404.title' | t }}
  </h1>
  {%- if customer -%}
    <a href="{{ routes.all_products_collection_url }}" class="button">
      {{ 'general.continue_shopping' | t }}
    </a>
  {%- else -%}
    <p style="color:#6b7280;margin:0 0 24px;font-size:15px;">Log in to browse the full Worthy Products catalogue.</p>
    <a href="/account/login" class="button button--primary">Log In to Your Account</a>
    <a href="/pages/wholesale-inquiries" class="button" style="margin-top:12px;">Apply for an Account</a>
  {%- endif -%}
</div>
