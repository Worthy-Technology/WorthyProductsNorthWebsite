{% layout none %}
[
  {% for item in search.results %}
    {
      "id": {{ item.id }},
      "title": "{{ item.title | escape }}",
      "handle": "{{ item.handle }}",
      "image": "{{ item.featured_image | image_url: width: 400 }}",
      "price": {{ item.price | money_without_currency | json }},
      "vendor": "{{ item.vendor | escape }}",
      "tags": {{ item.tags | json }},
      "variants": [
        {% for variant in item.variants %}
          { "id": {{ variant.id }}, "title": "{{ variant.title }}" }
          {% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]