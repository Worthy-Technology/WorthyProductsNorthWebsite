<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script src="{{ 'turn.min.js' | asset_url }}" defer="defer"></script>

<style>
  .magazine-viewport {
    overflow: hidden;
    width: 100%;
    height: 600px; /* Adjust based on your catalog aspect ratio */
    background-color: #f0f0f0;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20px 0;
  }
  #worthy-catalog {
    width: 800px; /* Total width (2 pages) */
    height: 500px;
  }
  #worthy-catalog .page {
    width: 400px;
    height: 500px;
    background-color: white;
    box-shadow: 0 0 5px rgba(0,0,0,0.1);
  }
  #worthy-catalog img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>

<div class="magazine-viewport">
  <div id="worthy-catalog">
    <div class="page" style="background-image:url('YOUR_PAGE_1_IMAGE_URL');"></div>
    <div class="page" style="background-image:url('YOUR_PAGE_2_IMAGE_URL');"></div>
    <div class="page" style="background-image:url('YOUR_PAGE_3_IMAGE_URL');"></div>
    </div>
</div>

<script>
  // Ensure scripts are loaded before initializing
  document.addEventListener('DOMContentLoaded', function() {
    var checkYield = setInterval(function() {
      if (window.jQuery && $.isFunction($.fn.turn)) {
        clearInterval(checkYield);
        initFlipbook();
      }
    }, 100);

    function initFlipbook() {
      $('#worthy-catalog').turn({
        width: 800,
        height: 500,
        autoCenter: true,
        gradients: true,
        acceleration: true,
        display: 'double', // Shows two pages at once
        when: {
          turning: function(event, page, view) {
             console.log('Worthy Catalog turning to page: ' + page);
          }
        }
      });
    }
  });
</script>
