<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/dflip@2.0.0/css/dflip.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/dflip@2.0.0/css/themify-icons.min.css">

<style>
  #worthy-pdf-container {
    width: 100%;
    height: 800px;
    background: #222;
    margin: 20px 0;
  }
</style>

<div id="worthy-pdf-container">
  <div class="_df_book" 
       source="/s/files/1/0530/2176/9881/files/Worthy_Products_CATALOGUE_2026-compressed_1.pdf" 
       id="worthy_catalogue">
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="{{ 'dflip.min.js' | asset_url }}"></script>

<script>
  var dFlipOptions = {
    // 1. Core PDF Engine
    pdfjsSrc: "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.10.377/pdf.min.js",
    pdfjsWorkerSrc: "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.10.377/pdf.worker.min.js",
    
    // 2. Performance for 1000 Pages
    webgl: false,              // Disables heavy 3D math
    autoEnableOutline: false,  // Speeds up initial load
    enableThumbnail: true,     
    duration: 500,
    
    // 3. The "Magic" Settings for Shopify Plus
    disableFontFace: true,     // Prevents font-loading delays
    cMapUrl: 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.10.377/cmaps/',
    cMapPacked: true,
    
    // 4. Force 2D Fallback if WebGL fails
    allControls: "altPrev,pageNumber,altNext,play,outline,thumbnail,zoomIn,zoomOut,fullScreen,download"
  };

  // Manual Trigger if the auto-init fails
  $(document).ready(function() {
    if ($("#worthy_catalogue").length > 0) {
       console.log("Worthy Catalog: Starting manual init...");
       // If it stays white, this forces the render
       setTimeout(function() {
         if($(".df-container").length == 0) {
            $("#worthy_catalogue").flipBook();
         }
       }, 1000);
    }
  });
</script>