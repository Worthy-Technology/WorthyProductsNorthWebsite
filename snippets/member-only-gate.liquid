{% comment %}
  Renders the "Trade Customers Only" access gate for guests visiting restricted pages.
  Usage: {% render 'member-only-gate' %}
{% endcomment %}

<style>
  :root {
    --mo-brand:        #2659c3;
    --mo-brand-mid:    #3f7adf;
    --mo-brand-light:  #528ef6;
    --mo-brand-lighter:#7caefd;
    --mo-muted:        #6b7280;
    --mo-bg:           #f8faff;
    --mo-ring:         rgba(38,89,195,0.18);
    --mo-shadow:       0 10px 25px rgba(0,0,0,0.06);
    --mo-radius:       18px;
  }

  .mo-wrapper {
    display: grid;
    place-items: center;
    padding: 40px 24px 60px;
    background: var(--mo-bg);
  }

  .mo-card {
    width: min(920px, 92vw);
    background: #fff;
    border-radius: var(--mo-radius);
    box-shadow: var(--mo-shadow);
    border: 1px solid var(--mo-ring);
    overflow: hidden;
  }

  .mo-hero {
    padding: 44px 28px 36px;
    background: linear-gradient(120deg, var(--mo-brand-light) 0%, var(--mo-brand-lighter) 100%);
    color: #fff;
    text-align: center;
  }

  .mo-lock {
    width: 72px;
    height: 72px;
    margin: 0 auto 20px;
    background: rgba(255,255,255,0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mo-hero h1 {
    margin: 0 0 14px;
    font-size: clamp(26px, 3vw, 38px);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .mo-hero p {
    margin: 0 auto;
    font-size: clamp(15px, 1.5vw, 17px);
    opacity: 0.95;
    max-width: 58ch;
    line-height: 1.6;
  }

  .mo-cta-row {
    margin-top: 30px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  .mo-btn {
    padding: 13px 26px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 15px;
    text-decoration: none !important;
    display: inline-block;
    transition: background 0.18s, color 0.18s, transform 0.1s;
    white-space: nowrap;
    cursor: pointer;
  }
  .mo-btn:active { transform: translateY(1px); }

  .mo-btn-white {
    background: #fff;
    color: var(--mo-brand);
  }
  .mo-btn-white:hover {
    background: var(--mo-brand-lighter);
    color: #fff;
  }

  .mo-btn-ghost {
    background: rgba(255,255,255,0.15);
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.45);
  }
  .mo-btn-ghost:hover { background: rgba(255,255,255,0.28); }

  .mo-panels {
    padding: 32px 28px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  @media (max-width: 680px) {
    .mo-panels { grid-template-columns: 1fr; }
    .mo-hero   { padding: 32px 20px 28px; }
  }

  .mo-panel {
    border: 1px solid var(--mo-ring);
    border-radius: 14px;
    padding: 24px 22px;
  }

  .mo-panel h2 {
    margin: 0 0 14px;
    font-size: 17px;
    font-weight: 700;
    color: var(--mo-brand);
  }

  .mo-panel p {
    color: var(--mo-muted);
    margin: 0 0 10px;
    font-size: 14px;
    line-height: 1.65;
  }

  .mo-steps {
    list-style: none;
    padding: 0;
    margin: 0 0 16px;
    counter-reset: step;
  }
  .mo-steps li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 12px;
    font-size: 14px;
    color: var(--mo-muted);
    line-height: 1.5;
  }
  .mo-steps li::before {
    counter-increment: step;
    content: counter(step);
    background: var(--mo-brand);
    color: #fff;
    min-width: 22px;
    height: 22px;
    border-radius: 50%;
    font-size: 12px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .mo-btn-solid {
    display: inline-block;
    background: var(--mo-brand);
    color: #fff !important;
    padding: 10px 20px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 14px;
    text-decoration: none !important;
    margin-top: 6px;
    transition: background 0.18s;
  }
  .mo-btn-solid:hover { background: var(--mo-brand-mid); }

  .mo-info-box {
    background: #f0f6ff;
    border-left: 4px solid var(--mo-brand-light);
    border-radius: 10px;
    padding: 16px 18px;
    margin-top: 16px;
  }
  .mo-info-box p {
    margin: 3px 0;
    font-size: 13px;
  }
  .mo-info-box a {
    color: var(--mo-brand);
    text-decoration: none;
  }
  .mo-info-box a:hover { text-decoration: underline; }
  .mo-info-hours {
    color: #9ca3af !important;
    font-size: 12px !important;
    margin-top: 6px !important;
  }
</style>

<div class="mo-wrapper">
  <section class="mo-card" role="main" aria-label="Members only area">

    <div class="mo-hero">
      <div class="mo-lock" aria-hidden="true">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5"
             stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      </div>

      <h1>Trade Customers Only</h1>
      <p>
        This area is for <strong>registered Worthy Products trade customers</strong>.
        Log in to view your prices, browse the full product range, and place orders.
      </p>

      <div class="mo-cta-row">
        <a href="/account/login" class="mo-btn mo-btn-white">Log In to Your Account</a>
        <a href="/pages/wholesale-inquiries" class="mo-btn mo-btn-ghost">Apply for an Account</a>
      </div>
    </div>

    <div class="mo-panels">

      <div class="mo-panel">
        <h2>How to log in</h2>
        <ul class="mo-steps">
          <li>Click <strong>Log In to Your Account</strong> above</li>
          <li>Enter your <strong>Store ID</strong> and <strong>password</strong></li>
          <li>Access your personal prices, product catalogue, and order history</li>
        </ul>
        <p>
          First time? Or forgot your password? Click <em>"Set up or reset your password"</em>
          on the login page and we will email you a setup link straight away.
        </p>
      </div>

      <div class="mo-panel">
        <h2>Not a customer yet?</h2>
        <p>
          Worthy Products is New Zealand's premier FMCG wholesale distributor,
          servicing 3,000+ customers across New Zealand, Australia, and the Pacific.
        </p>
        <p>Apply to open a trade account and get access to trade pricing across our full range.</p>
        <a href="/pages/wholesale-inquiries" class="mo-btn-solid">Apply for a Trade Account</a>

        <div class="mo-info-box">
          <p><strong>Have a question? Get in touch:</strong></p>
          <p>Email: <a href="mailto:admin@worthyproducts.nz">admin@worthyproducts.nz</a></p>
          <p>Phone: <a href="tel:+6495804110">09 580 4110</a></p>
          <p class="mo-info-hours">Monday to Friday, 8am to 4pm NZT</p>
        </div>
      </div>

    </div>

  </section>
</div>
