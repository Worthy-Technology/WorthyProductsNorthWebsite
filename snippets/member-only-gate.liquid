{% comment %}
  Renders the Members-Only Access gate for guests on restricted pages.
  Usage: {% render 'member-only-gate' %}
{% endcomment %}

<style>
  .mo-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(24px, 5vw, 64px) clamp(12px, 4vw, 20px);
    background: #f4f7ff;
    min-height: auto;
  }

  .mo-card {
    width: min(980px, 100%);
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 6px 32px rgba(38,89,195,0.09);
    border: 1.5px solid rgba(38,89,195,0.13);
    overflow: hidden;
  }

  /* ── Header ───────────────────────────── */
  .mo-header {
    text-align: center;
    padding: clamp(28px, 5vw, 52px) clamp(20px, 4vw, 40px) clamp(24px, 4vw, 40px);
  }

  .mo-lock-circle {
    width: clamp(60px, 10vw, 82px);
    height: clamp(60px, 10vw, 82px);
    background: #2659c3;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto clamp(14px, 3vw, 22px);
    box-shadow: 0 4px 20px rgba(38,89,195,0.3);
  }

  .mo-lock-circle svg {
    width: clamp(24px, 4vw, 34px);
    height: clamp(24px, 4vw, 34px);
  }

  .mo-header h1 {
    font-size: clamp(20px, 3.5vw, 30px);
    font-weight: 800;
    color: #111827;
    margin: 0 0 10px;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .mo-header p {
    font-size: clamp(13px, 1.8vw, 15px);
    color: #6b7280;
    max-width: 52ch;
    margin: 0 auto;
    line-height: 1.65;
  }

  .mo-sep {
    height: 1px;
    background: rgba(38,89,195,0.1);
    margin: 0 clamp(16px, 4vw, 32px);
  }

  /* ── Three-column options ─────────────── */
  .mo-options {
    display: grid;
    grid-template-columns: 1fr 1.05fr 1fr;
    gap: clamp(12px, 2.5vw, 20px);
    padding: clamp(20px, 4vw, 36px) clamp(16px, 3vw, 32px) clamp(24px, 4vw, 40px);
    align-items: start;
  }

  /* Tablet: 2 + 1 stacked or all column depending on width */
  @media (max-width: 820px) {
    .mo-options {
      grid-template-columns: 1fr;
      gap: 14px;
      padding: 20px 16px 28px;
    }
    .mo-option--featured {
      transform: none;
      order: -1;
    }
  }

  /* ── Option card ──────────────────────── */
  .mo-option {
    border-radius: 16px;
    padding: clamp(20px, 3vw, 28px) clamp(16px, 2.5vw, 22px) clamp(18px, 3vw, 24px);
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1.5px solid rgba(38,89,195,0.14);
    background: #fff;
  }

  .mo-option--featured {
    background: linear-gradient(150deg, #2659c3 0%, #1b46a8 100%);
    border-color: transparent;
    box-shadow: 0 10px 36px rgba(38,89,195,0.36);
    transform: translateY(-10px);
  }

  /* ── Icon box ─────────────────────────── */
  .mo-icon {
    width: clamp(44px, 6vw, 54px);
    height: clamp(44px, 6vw, 54px);
    border-radius: 14px;
    background: #eff4ff;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: clamp(12px, 2vw, 18px);
    flex-shrink: 0;
  }

  .mo-icon svg {
    width: clamp(20px, 3vw, 26px);
    height: clamp(20px, 3vw, 26px);
  }

  .mo-option--featured .mo-icon {
    background: rgba(255,255,255,0.18);
  }

  /* ── Badge ────────────────────────────── */
  .mo-badge {
    display: inline-block;
    background: rgba(255,255,255,0.22);
    color: #fff;
    font-size: clamp(9px, 1.2vw, 10px);
    font-weight: 800;
    letter-spacing: 0.12em;
    padding: 3px 10px;
    border-radius: 20px;
    margin-bottom: 12px;
    align-self: flex-start;
  }

  /* ── Text ─────────────────────────────── */
  .mo-option h2 {
    font-size: clamp(14px, 2vw, 16.5px);
    font-weight: 700;
    color: #111827;
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .mo-option--featured h2 { color: #fff; }

  .mo-option p {
    font-size: clamp(12.5px, 1.7vw, 13.5px);
    color: #6b7280;
    line-height: 1.65;
    margin: 0 0 20px;
    flex: 1;
  }

  .mo-option--featured p {
    color: rgba(255,255,255,0.82);
  }

  .mo-option--featured p strong { color: #fff; }

  .mo-option--featured p a {
    color: #fff;
    text-decoration: underline;
  }

  /* ── Buttons ──────────────────────────── */
  .mo-btn {
    display: block;
    text-align: center;
    padding: clamp(11px, 1.8vw, 13px) clamp(14px, 2vw, 20px);
    border-radius: 10px;
    font-weight: 700;
    font-size: clamp(13px, 1.6vw, 14px);
    text-decoration: none !important;
    transition: background 0.15s ease, color 0.15s ease, transform 0.1s ease;
    cursor: pointer;
    white-space: nowrap;
    margin-top: auto;
    min-height: 46px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mo-btn:active { transform: translateY(1px); }

  .mo-btn--outline {
    border: 2px solid #2659c3;
    color: #2659c3 !important;
    background: transparent;
  }
  .mo-btn--outline:hover {
    background: #2659c3;
    color: #fff !important;
  }

  .mo-btn--white {
    background: #fff;
    color: #2659c3 !important;
  }
  .mo-btn--white:hover {
    background: #eff4ff;
    color: #1b46a8 !important;
  }

  .mo-btn--solid {
    background: #2659c3;
    color: #fff !important;
  }
  .mo-btn--solid:hover {
    background: #1b46a8;
  }

  /* Mobile-specific tweaks */
  @media (max-width: 480px) {
    .mo-card {
      border-radius: 16px;
    }
    .mo-option {
      border-radius: 12px;
    }
    .mo-btn {
      white-space: normal;
    }
  }
</style>

<div class="mo-wrap">
  <div class="mo-card">

    <!-- Header -->
    <div class="mo-header">
      <div class="mo-lock-circle" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none"
             stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      </div>
      <h1>Members-Only Access</h1>
      <p>You're trying to access content exclusive to registered Worthy Products customers. Please choose one of the options below to continue.</p>
    </div>

    <div class="mo-sep"></div>

    <!-- Three options -->
    <div class="mo-options">

      <!-- 1. Already a customer -->
      <div class="mo-option">
        <div class="mo-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none"
               stroke="#2659c3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </div>
        <h2>Already a Customer?</h2>
        <p>Log in to access your exclusive wholesale pricing, full product catalogue, and order history.</p>
        <a href="/pages/b2b-login" class="mo-btn mo-btn--outline">Log In to Your Account &rarr;</a>
      </div>

      <!-- 2. Open B2B account (featured) -->
      <div class="mo-option mo-option--featured">
        <span class="mo-badge">RECOMMENDED</span>
        <div class="mo-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none"
               stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
        </div>
        <h2>Open a B2B Wholesale Account</h2>
        <p>Download our <strong>Direct Debit</strong> and <strong>Credit Application</strong> forms, complete both, and email them to <a href="mailto:admin@worthyproducts.nz">admin@worthyproducts.nz</a> and our team will have your account ready.</p>
        <a href="/pages/wholesale-inquiries" class="mo-btn mo-btn--white">Get Application Forms &rarr;</a>
      </div>

      <!-- 3. Retail customer -->
      <div class="mo-option">
        <div class="mo-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none"
               stroke="#2659c3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"/>
            <circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
        </div>
        <h2>Shop as a Retail Customer</h2>
        <p>Not a wholesale buyer? Create a free retail account to shop at standard B2C pricing. Full payment is required when placing your order.</p>
        <a href="/account/register" class="mo-btn mo-btn--solid">Create Account &rarr;</a>
      </div>

    </div>
  </div>
</div>
