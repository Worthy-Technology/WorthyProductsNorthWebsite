    <!-- Start: Whitelist all account routes and existing paths to prevent unwanted login redirects - Pratham -->
    {% comment %}
    Purpose- Allow all Shopify account routes plus your existing public paths, so invites and resets reach Create Password instead of being forced to /account/login.
    {% endcomment %}
   {% unless Shopify.designMode %}
    {% if customer %}
      {%- comment -%} Logged in — no redirect {%- endcomment -%}
    {% else %}
      {%- assign allowed_exact = '/' | append: ',/account' | append: ',/account/login' | append: ',/account/register' | append: ',/account/recover' | append: ',/pages/contact' | append: ',/pages/product-catalog' | append: ',/pages/about-us' | split: ',' -%}
      {%- assign allowed_prefixes = '/account/activate,/account/reset,/account/orders,/account/addresses,/account/logout' | split: ',' -%}
      {%- assign current_path = request.path | downcase -%}
      {%- assign allowed = false -%}

      {%- for path in allowed_exact -%}
{%- comment -%} Wholesale_Hub_Product_Visibility_For_Loop Start {%- endcomment -%}
{%- capture hide_resource -%}{% render "orbit_wholesale_product_visibility", resource: path %}{%- endcapture -%}
{%- if hide_resource == "true" -%}
  {% continue %}
{%- endif -%}
{%- comment -%} Wholesale_Hub_Product_Visibility_For_Loop End {%- endcomment -%}

        {%- if current_path == path -%}{%- assign allowed = true -%}{%- endif -%}
      {%- endfor -%}
      {%- if allowed == false -%}
        {%- for prefix in allowed_prefixes -%}
{%- comment -%} Wholesale_Hub_Product_Visibility_For_Loop Start {%- endcomment -%}
{%- capture hide_resource -%}{% render "orbit_wholesale_product_visibility", resource: prefix %}{%- endcapture -%}
{%- if hide_resource == "true" -%}
  {% continue %}
{%- endif -%}
{%- comment -%} Wholesale_Hub_Product_Visibility_For_Loop End {%- endcomment -%}

          {%- assign head = current_path | slice: 0, prefix.size -%}
          {%- if head == prefix -%}{%- assign allowed = true -%}{%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      {%- if allowed == false and current_path contains '/policies/' -%}
