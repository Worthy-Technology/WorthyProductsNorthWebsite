      <style>
        /* Back in stock loading spinner */
      /* Spinner */
      .bis-spinner {
        width: 18px;
        height: 18px;
        border: 2px solid rgba(255,255,255,0.4);
        border-top-color: #fff;
        border-radius: 50%;
        display: inline-block;
        animation: bis-spin 0.6s linear infinite;
        vertical-align: middle;
      }

      @keyframes bis-spin {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
      }

      /* Messages */
      .bis-message {
        font-size: 0.9rem;
        margin-top: 8px;
        line-height: 1.4;
      }

      .bis-success { 
        color: #00a862;
        background-color: white;
        padding: 10px;
        font-size: 12px; } /* Theme green */
      .bis-error { color: #e03a3a; } /* Red */

      .bis-animate {
        animation: bis-fade-in 0.3s ease-out;
      }

      @keyframes bis-fade-in {
        from { opacity: 0; transform: translateY(4px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      </style>
   {% comment %} End Back in Stock Block CSS - Pratham {% endcomment %}


